{
  "name": "bunrun",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "BUNRUN_DEV=1 concurrently -n server,vite -c blue,green --kill-others \"bun run server\" \"vite\"",
    "dev:server": "bun run server",
    "dev:ui": "vite",
    "build": "vite build",
    "bunrun": "bun run server",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tsconfig/bun": "^1.0.7",
    "@tsconfig/svelte": "^5.0.4",
    "@types/bun": "^1.3.14",
    "concurrently": "^9.1.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.34.0",
    "svelte-check": "^4.2.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
